# Provider de LLM: "groq" (padrão) ou "openrouter"
NIMBUS_PROVIDER=groq

# --- Groq (https://console.groq.com) ---
GROQ_API_KEY=your_groq_key_here
# Modelo padrão se usar Groq:
# NIMBUS_MODEL=llama-3.3-70b-versatile

# --- OpenRouter (https://openrouter.ai/keys) ---
# OPENROUTER_API_KEY=your_openrouter_key_here
# Modelo no formato OpenRouter (provider/model):
# NIMBUS_MODEL=meta-llama/llama-3.3-70b-instruct
# Outros exemplos:
# NIMBUS_MODEL=anthropic/claude-3.5-sonnet
# NIMBUS_MODEL=openai/gpt-4o-mini
# NIMBUS_MODEL=google/gemini-2.0-flash-001
